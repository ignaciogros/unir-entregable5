# ============================================================
# COPIA ESTE FICHERO A .env Y RELLENA CON TUS VALORES REALES
# Nunca pongas credenciales reales en .env.example
# ============================================================

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21

# PostgreSQL (en local usa estos valores; en prod sobreescribe con DATABASE_URL)
DATABASE_URL=postgresql://raguser:ragpass@db:5432/ragdb

# Qdrant (en local apunta al contenedor; en prod usa URL de Qdrant Cloud)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Aplicación — los valores reales vienen de GitHub Secrets en producción
SECRET_KEY=changeme-replace-with-random-32-char-string
APP_USER=changeme
APP_PASSWORD=changeme
